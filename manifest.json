{
  "manifest_version": 3,
  "name": "Solicitud Ambulatorio",
  "version": "1.1",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://micamsalud.com.ar/*",
    "*://*.micamsalud.com.ar/*",
    "https://facundo598.github.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "file:///*",
        "https://facundo598.github.io/*",
        "*://micamsalud.com.ar/*",
        "*://*.micamsalud.com.ar/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
